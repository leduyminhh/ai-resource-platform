{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ARPS Resource",
  "type": "object",
  "required": [
    "apiVersion",
    "kind",
    "metadata",
    "spec"
  ],
  "properties": {
    "apiVersion": {
      "type": "string"
    },
    "kind": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "required": [
        "id",
        "name",
        "version"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "labels": {
          "type": "object"
        },
        "annotations": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "spec": {
      "type": "object"
    },
    "status": {
      "type": "object"
    }
  },
  "additionalProperties": false
}